<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} | {% endif %}Bellevue ARC</title>
    <meta name="description" content="{{ description or 'Bellevue ARC - a fan site for the Bellevue Amateur Radio Club' }}">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="site-header">
        <div class="container">
            <div class="header-content">
                <div class="logo">
                    <h1><a href="/">Bellevue ARC</a>
                    <p class="tagline">a fan site for the <a href="http://www.bellevuearc.org/">Bellevue Amateur Radio Club</a></p>
                    </h1>
                </div>
            </div>
        </div>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Pull requests welcome <a href="https://github.com/payne/bellevuearc.net">https://github.com/payne/bellevuearc.net</a></h3>
                </div>
        </div>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>